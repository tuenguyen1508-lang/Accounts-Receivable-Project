# ---- Secrets (never commit) ----
.env
.env.*
# .env.template holds placeholders only and is safe to commit:
!.env.template

# ---- Python bytecode / build / envs ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/

# ---- Generated data (regenerated by the pipeline) ----
# Raw inputs (data/raw/) ARE tracked - they are the source of truth.
# Processed outputs are regenerated on every run; ignore their contents.
data/processed/*
!data/processed/.gitkeep

# ---- Logs / temp ----
*.log
*.tmp

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
.vscode/
.idea/

# NOTE: sql/ is intentionally NOT ignored - sql/create_schema.sql is source code
# for the database schema and must stay tracked.
