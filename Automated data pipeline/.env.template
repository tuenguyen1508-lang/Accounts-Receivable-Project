# Copy this file to ".env" and fill in your Supabase / PostgreSQL credentials.
# .env is read by pipeline.py at load time. NEVER commit the real .env to git.
#
# These values use the Supabase TRANSACTION POOLER (Project Settings -> Database ->
# Connection string -> Transaction pooler). Note the user is "postgres.<project-ref>".

SUPABASE_DB_HOST=aws-0-<region>.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.<your-project-ref>
SUPABASE_DB_PASSWORD=<your-database-password>
